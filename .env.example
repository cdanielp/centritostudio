# Centrito Studio — variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# .env está en .gitignore — NUNCA lo commitees.

# ── Cerebro editorial (Fase 2) ──────────────────────────────
# Provider LLM intercambiable: deepseek | anthropic | ollama | mock
LLM_PROVIDER=deepseek

# DeepSeek (default) — obtener key en https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxx

# ── Submagic (motor nube opt-in) ────────────────────────────
# Estacion independiente que edita el video en la nube de Submagic.
# Obtener key en https://submagic.co — header x-api-key.
SUBMAGIC_API_KEY=

# ── Pexels (b-roll de imagenes de stock, opt-in) ────────────
# Fetcher de imagenes para b-roll cutaway. Obtener key gratis en
# https://www.pexels.com/api — header Authorization. Sin key la capa
# de b-roll queda deshabilitada (fail-open, el pipeline sigue).
PEXELS_API_KEY=

# ── Whisper / HuggingFace ───────────────────────────────────
# Necesario en Windows sin Developer Mode (evita warning de symlinks)
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# ── Python / consola ────────────────────────────────────────
PYTHONIOENCODING=utf-8
